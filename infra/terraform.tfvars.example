# Copy this file to terraform.tfvars and fill in real values.
# NEVER commit terraform.tfvars – it is in .gitignore.

aws_region      = "us-east-1"
environment     = "dev"
project_name    = "polyglot"
instance_type   = "t3.small"

# Name of the key pair already created in AWS Console
key_name        = "your-key-pair-name"

# Your public IP (curl ifconfig.me)
my_ip_cidr      = "YOUR_IP/32"

# Docker Hub username (used in docker-stack.yml)
docker_username = "your-dockerhub-username"

image_tag       = "latest"
